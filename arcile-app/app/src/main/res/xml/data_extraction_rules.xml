<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="trash_crypto_prefs.xml" />
        <exclude domain="file" path="datastore/browser_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/quick_access_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/storage_classifications_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/onboarding_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/theme_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/activity_log.preferences_pb" />
        <exclude domain="file" path="datastore/operation_journal.preferences_pb" />
        <exclude domain="file" path="datastore" />
        <exclude domain="file" path="analytics" />
        <exclude domain="file" path="operation_journal" />
        <exclude domain="file" path="staging" />
        <exclude domain="file" path=".arcile" />
        <exclude domain="external" path=".arcile" />
        <exclude domain="database" path="arcile-cache.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="trash_crypto_prefs.xml" />
        <exclude domain="file" path="datastore/browser_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/quick_access_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/storage_classifications_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/onboarding_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/theme_prefs.preferences_pb" />
        <exclude domain="file" path="datastore/activity_log.preferences_pb" />
        <exclude domain="file" path="datastore/operation_journal.preferences_pb" />
        <exclude domain="file" path="datastore" />
        <exclude domain="file" path="analytics" />
        <exclude domain="file" path="operation_journal" />
        <exclude domain="file" path="staging" />
        <exclude domain="file" path=".arcile" />
        <exclude domain="external" path=".arcile" />
        <exclude domain="database" path="arcile-cache.db" />
    </device-transfer>
</data-extraction-rules>
